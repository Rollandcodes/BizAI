# Core app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI
OPENAI_API_KEY=

# Airtable leads source (optional; falls back to Supabase leads)
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_LEADS_TABLE=Leads

# WhatsApp Cloud API
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_GRAPH_API_VERSION=v21.0
WHATSAPP_DEFAULT_BUSINESS_ID=

# Admin/API protection
ADMIN_SECRET=
ADMIN_API_KEY=
ADMIN_EMAIL=noreply@cypai.app
AGENCY_ALLOWED_EMAILS=

# Google Calendar integration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# SMTP email (contact/blog/booking notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="CypAI <noreply@cypai.app>"

# Resend email (automation alerts/retries)
RESEND_API_KEY=
RESEND_FROM_EMAIL="CypAI <noreply@cypai.app>"

# Automation webhook signing
AUTOMATION_ALERT_WEBHOOK_SECRET=
